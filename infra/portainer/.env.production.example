# Modelo pós-bootstrap (produção ou staging). Copiar valores para o `.env` da stack ou variáveis no Portainer.
# Não commitar este ficheiro preenchido com segredos reais.

# Após a primeira subida com dados seedados, desligar o seed em cada restart:
# (O `dev_seed` é idempotente, mas RUN_SEED=false evita trabalho e avisos no entrypoint.)
RUN_SEED=false
ENVIRONMENT=production

# JWT e passwords: gerar valores novos (não reutilizar os de desenvolvimento).
# JWT_SECRET=
# POSTGRES_PASSWORD=
# MINIO_ROOT_PASSWORD=

# Rate limit: se o tráfego à API for só via container `web` (Nginx → api) e a porta da API
# não estiver exposta ao público, pode usar RATE_LIMIT_TRUST_PROXY=true (X-Forwarded-For no nginx.conf).
# Se `API_PUBLISH` estiver aberto na Internet, manter false.
# RATE_LIMIT_TRUST_PROXY=false
# REFRESH_RATE_LIMIT=120/minute

# CORS: domínio real do front (vírgula se vários).
# CORS_ORIGINS=https://app.exemplo.com
