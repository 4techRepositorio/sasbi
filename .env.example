# Ambiente de desenvolvimento — valores definidos para uso local.
# Em produção, gere segredos novos e não reutilize estes.

POSTGRES_USER=fourpro
POSTGRES_PASSWORD=K8mpQ4wxN2vR7sFourProBIdev2026
POSTGRES_DB=fourpro
# Host: 15432 → container 5432 (evita choque com Postgres local na 5432).
POSTGRES_PORT=15432

# Host: 16379 → container 6379 (evita choque com Redis local na 6379).
REDIS_PORT=16379

MINIO_ROOT_USER=fourpro
MINIO_ROOT_PASSWORD=M9nqR5syO3tS8uFourProMinio2026
MINIO_PORT=17291
MINIO_CONSOLE_PORT=17292

# URL alinhada com POSTGRES_PASSWORD acima
DATABASE_URL=postgresql+psycopg2://fourpro:K8mpQ4wxN2vR7sFourProBIdev2026@127.0.0.1:15432/fourpro
REDIS_URL=redis://127.0.0.1:16379/0

UPLOAD_DIR=/opt/4Pro_BI/.dev_uploads
MAX_UPLOAD_MB=50

# JWT (mínimo de entropia; trocar em produção)
JWT_SECRET=fourpro-bi-dev-jwt-hs256-2026-substituir-em-producao-64chars___
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Limite slowapi em POST /auth/refresh (ex.: subir atrás de proxy com muitos clientes no mesmo IP).
REFRESH_RATE_LIMIT=120/minute
# true = slowapi usa o cliente em X-Forwarded-For (só atrás de proxy de confiança).
RATE_LIMIT_TRUST_PROXY=false

ENVIRONMENT=development
LOG_LEVEL=INFO

# Origens CORS (vírgula) para o front; use * só em dev sem cookies — API ajusta credentials.
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8081,http://127.0.0.1:8081

# Email (opcional). Sem SMTP_HOST, reset/MFA só registam em log (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@4pro-bi.local
SMTP_USE_TLS=true
APP_PUBLIC_URL=http://localhost:8081

# Front (dev) — 80, 81, 82 e 8080 evitados no host
WEB_PUBLISH=8081
API_PUBLISH=7418
