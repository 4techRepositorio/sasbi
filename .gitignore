# Monorepo 4Pro_BI — raiz (venv QA, Python, segredos, artefactos)

# Python / QA (F5: scripts/run-qa-gates.sh usa .venv na raiz)
.venv/
venv/
apps/api/.venv/
apps/worker/.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Segredos e ambiente local
.env
.env.*
!.env.example
!e2e/.env.example
!e2e/.env.e2e.example
!infra/compose/.env.example
!infra/portainer/.env.example
!infra/portainer/.env.production.example

# Infra local (nunca commitar passwords/JWT)
infra/compose/.env
infra/portainer/.env

# Node (se existir na raiz ou em e2e)
node_modules/

# E2E / Playwright (futuro)
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/.cache/

# IDE / SO
.idea/
*.swp
.DS_Store
Thumbs.db

