# Modelo para e2e/.env.e2e (não commitar credenciais reais).
#   cp e2e/.env.e2e.example e2e/.env.e2e
#
# Após migrações + seed na API:
#   cd apps/api && alembic upgrade head && python -m fourpro_api.dev_seed
#
# Stack dev local (host partilhado): API = API_PUBLISH no .env raiz (7418) + ng serve :4200
#
# Stack Docker (infra/portainer — WEB_PUBLISH=8081, API_PUBLISH=6418):
#   PLAYWRIGHT_BASE_URL=http://127.0.0.1:8081
#   E2E_API_BASE_URL=http://127.0.0.1:6418

PLAYWRIGHT_BASE_URL=http://127.0.0.1:4200
E2E_RUN=1

# dev_seed — consumer (RBAC upload)
E2E_CONSUMER_EMAIL=consumer@local.dev
E2E_CONSUMER_PASSWORD=changeme

# dev_seed — admin, sem MFA (login smoke)
E2E_USER_EMAIL=admin@local.dev
E2E_USER_PASSWORD=changeme

# Smoke HTTP (run-e2e-api-smoke.sh); alinhar a API_PUBLISH (ex. 7418) ou Portainer (6418)
E2E_API_BASE_URL=http://127.0.0.1:7418

# Primeira vez com browser local:
#   E2E_INSTALL_BROWSERS=1 ./scripts/run-e2e-ui-login-smoke.sh
#
# Capturas PNG para docs/wireframes (opcional; requer front no ar):
#   E2E_WIREFRAME_CAPTURES=1 npm run test:wireframe-captures
