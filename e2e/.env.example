# Copiar: cp e2e/.env.example e2e/.env.e2e
# Ver e2e/README.md, scripts/run-e2e-local.sh, run-e2e-all-local.sh.
# Credenciais = `python -m fourpro_api.dev_seed` (admin + consumer) e workflow e2e-dispatch.
# Stack típica: API :8000 + ng serve --proxy-config proxy.conf.ci.json :4200
# Docker Portainer: web :8081, API :6418 → PLAYWRIGHT_BASE_URL + E2E_API_BASE_URL nessas portas.
# Primeira vez com browser: na pasta e2e → npm run install:browsers (ou sudo npx playwright install-deps chromium)

PLAYWRIGHT_BASE_URL=http://127.0.0.1:4200
E2E_RUN=1

# RBAC (upload) — após dev_seed: consumer@local.dev / changeme
E2E_CONSUMER_EMAIL=consumer@local.dev
E2E_CONSUMER_PASSWORD=changeme

# Login smoke + auditoria UI — admin@local.dev / changeme (papel admin, sem MFA)
E2E_USER_EMAIL=admin@local.dev
E2E_USER_PASSWORD=changeme

# API smoke (GET /health)
E2E_API_BASE_URL=http://127.0.0.1:8000

# Opcional: `context-storage-ui.spec.ts` — 2.º teste exige tenant com uso ≥90 % do plano
# E2E_EXPECT_STORAGE_WARN=1
# Preparar dados: na raiz do repo → ./scripts/run-seed-e2e-storage-warn.sh (com DATABASE_URL)
# Reverter: ./scripts/run-cleanup-e2e-storage-warn.sh
